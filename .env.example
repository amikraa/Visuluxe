# ============================================
# Visuluxe Environment Configuration Template
# ============================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER COMMIT THE ACTUAL .env FILE TO VERSION CONTROL
# ============================================

# Frontend (Vite) Supabase settings
# Get these from your Supabase project settings
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key
# Backwards-compatible name (supported by code, but prefer VITE_SUPABASE_ANON_KEY)
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-public-key
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# IMPORTANT: The service role key should ONLY be used in secure server environments
# Never expose this in frontend code or commit to version control
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key